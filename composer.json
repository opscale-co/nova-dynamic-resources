{
  "name": "opscale-co/nova-dynamic-resources",
  "description": "Config-based rendering for Nova resources",
  "keywords": [
    "laravel",
    "nova",
    "package",
    "tool",
    "opscale",
    "dynamic",
    "resources"
  ],
  "repositories": [
    {
      "type": "composer",
      "url": "https://nova.laravel.com"
    }
  ],
  "homepage": "https://github.com/opscale-co/nova-dynamic-resources",
  "license": "MIT",
  "authors": [
    {
      "name": "Opscale",
      "email": "development@opscale.co",
      "role": "Developer"
    }
  ],
  "require": {
    "php": "^8.3",
    "opscale-co/actions": "^2.0.1",
    "opscale-co/nova-bpmn-field": "^1.0",
    "opscale-co/nova-catalogs": "^1.3.1",
    "opscale-co/nova-dbml-field": "^1.0",
    "opscale-co/nova-geospatial-fields": "^1.1",
    "opscale-co/nova-package-tools": "^1.1",
    "opscale-co/validations": "^1.0"
  },
  "autoload": {
    "psr-4": {
      "Opscale\\NovaDynamicResources\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Opscale\\NovaDynamicResources\\Tests\\": "tests",
      "Workbench\\App\\": "workbench/app/",
      "Workbench\\Database\\Factories\\": "workbench/database/factories/",
      "Workbench\\Database\\Seeders\\": "workbench/database/seeders/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Opscale\\NovaDynamicResources\\PackageServiceProvider"
      ]
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "require-dev": {
    "driftingly/rector-laravel": "^2.5",
    "larastan/larastan": "^3.10",
    "laravel/nova": "^5.9",
    "laravel/nova-devtool": "^1.10",
    "mockery/mockery": "^1.6",
    "opscale-co/strict-rules": "^1.3",
    "orchestra/testbench-dusk": "^10.10",
    "pestphp/pest": "^4.7",
    "pestphp/pest-plugin-laravel": "^4.1",
    "phpunit/phpunit": "^12.5",
    "rector/rector": "^2.5",
    "tightenco/duster": "^3.4"
  },
  "scripts": {
    "post-autoload-dump": [
      "@clear",
      "@prepare"
    ],
    "clear": "@php vendor/bin/testbench package:purge-skeleton --ansi",
    "prepare": "@php vendor/bin/testbench package:discover --ansi",
    "build": "@php vendor/bin/testbench workbench:build --ansi",
    "serve": [
      "Composer\\Config::disableProcessTimeout",
      "@php vendor/bin/testbench serve --ansi"
    ]
  },
  "version": "1.11.1"
}
